{
  // vim:set ft=jsonc:
  "name": "Dockerfile",
  "dockerFile": "../Dockerfile",

  "settings": {},

  "extensions": [
    "dbaeumer.vscode-eslint",
    "kumar-harsh.graphql-for-vscode",
    "exiasr.hadolint",
    "bierner.markdown-emoji",
    "bierner.markdown-preview-github-styles",
    "esbenp.prettier-vscode",
    "editorconfig.editorconfig",
    "nickytonline.gatsby-extension-pack",
    "eliostruyf.vscode-front-matter"
  ],

  "appPort": [3000],
  "remoteUser": "node",
  "build": {
    "target": "development"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "src=${localWorkspaceFolder},dst=/workspace,type=bind,consistency=cached",
  "mounts": [
    "source=${localEnv:HOME}/.dotfiles,target=/home/node/.dotfiles,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.dotfiles-personal,target=/home/node/.dotfiles-personal,type=bind,consistency=cached",
    "src=docwhat-docwhat-node_modules,dst=/workspace/node_modules,type=volume",
    "source=docwhat-docwhat-vscode-server-extenstions,target=/home/node/.vscode-server/extensions,type=volume",
    "source=docwhat-docwhat-vscode-server-insiders-extenstions-insiders,target=/home/node/.vscode-server-insiders/extensions,type=volume"
  ],
  "postCreateCommand": "sudo chown node node_modules"
}
